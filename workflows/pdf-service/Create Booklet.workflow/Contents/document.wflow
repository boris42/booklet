				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run AppleScript.action</string>
				<key>ActionName</key>
				<string>Run AppleScript</string>
				<key>ActionParameters</key>
				<dict>
					<key>source</key>
					<string>on run {input, parameters}	set bookletTool to "/Library/Application Support/Create Booklet/booklet"		if (count of input) is 0 then		display dialog "No PDF files were passed to the workflow." buttons {"OK"} default button "OK"		return input	end if		try		do shell script "test -x " &amp; quoted form of bookletTool	on error		display dialog "Create Booklet helper was not found or is not executable:" &amp; return &amp; return &amp; bookletTool buttons {"OK"} default button "OK"		return input	end try		set creepChoice to button returned of (display dialog "Apply creep compensation?" buttons {"No", "Yes"} default button "Yes")		set extraArgs to ""		if creepChoice is "Yes" then		set innerResult to display dialog "Sheet thickness / creep increment per folded sheet, in mm:" default answer "0.02" buttons {"Cancel", "OK"} default button "OK" cancel button "Cancel"		set innerMM to text returned of innerResult				set coverResult to display dialog "Cover thickness in mm. Use 0 if cover is same paper or there is no separate heavier cover:" default answer "0" buttons {"Cancel", "OK"} default button "OK" cancel button "Cancel"		set coverMM to text returned of coverResult				set innerMM to my normalizeNumberText(innerMM)		set coverMM to my normalizeNumberText(coverMM)				if innerMM is "" then			display dialog "Sheet thickness cannot be blank." buttons {"OK"} default button "OK"			return input		end if				set innerState to my decimalNumberState(innerMM)				if innerState is "invalid" then			display dialog "Sheet thickness is not a valid number:" &amp; return &amp; return &amp; innerMM buttons {"OK"} default button "OK"			return input		end if				if innerState is "zero" then			display dialog "Sheet thickness must be greater than 0." buttons {"OK"} default button "OK"			return input		end if				set extraArgs to " --sheet-thickness " &amp; quoted form of innerMM				if coverMM is not "" then			set coverState to my decimalNumberState(coverMM)						if coverState is "invalid" then				display dialog "Cover thickness is not a valid number:" &amp; return &amp; return &amp; coverMM buttons {"OK"} default button "OK"				return input			end if						if coverState is "positive" then				set extraArgs to extraArgs &amp; " --cover-thickness " &amp; quoted form of coverMM			end if		end if	end if		repeat with f in input		set pdfPath to POSIX path of f		set cmd to quoted form of bookletTool &amp; extraArgs &amp; " " &amp; quoted form of pdfPath				try			do shell script cmd		on error errMsg number errNum			display dialog "Create Booklet failed for:" &amp; return &amp; pdfPath &amp; return &amp; return &amp; errMsg buttons {"OK"} default button "OK"			error number errNum		end try	end repeat		return inputend runon decimalNumberState(theText)	try		set cmd to "/usr/bin/awk -v x=" &amp; quoted form of theText &amp; " 'BEGIN { if (x !~ /^([0-9]+([.][0-9]*)?|[.][0-9]+)$/) print \"invalid\"; else if (x + 0 &gt; 0) print \"positive\"; else print \"zero\" }'"		return do shell script cmd	on error		return "invalid"	end tryend decimalNumberStateon normalizeNumberText(theText)	set theText to my trimText(theText)	set theText to my replaceText(theText, ",", ".")	return theTextend normalizeNumberTexton replaceText(theText, searchString, replacementString)	set oldDelimiters to AppleScript's text item delimiters	set AppleScript's text item delimiters to searchString	set textItems to text items of theText	set AppleScript's text item delimiters to replacementString	set newText to textItems as text	set AppleScript's text item delimiters to oldDelimiters	return newTextend replaceTexton trimText(theText)	set whiteSpaceChars to {" ", tab, return, linefeed}		repeat while theText is not "" and first character of theText is in whiteSpaceChars		set theText to text 2 thru -1 of theText	end repeat		repeat while theText is not "" and last character of theText is in whiteSpaceChars		set theText to text 1 thru -2 of theText	end repeat		return theTextend trimText</string>
				</dict>
